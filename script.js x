// ===============================
// NEUROCHAT V2 - PART 1
// Import Firebase
// ===============================

import { auth, db } from "./firebase.js";

import {
collection,
addDoc,
getDocs,
query,
where,
orderBy,
serverTimestamp
}
from "https://www.gstatic.com/firebasejs/12.0.0/firebase-firestore.js";

import {
signOut
}
from "https://www.gstatic.com/firebasejs/12.0.0/firebase-auth.js";

// ===============================
// Server URL
// ===============================

const SERVER_URL =
"https://my-ai-app-5.onrender.com";

// ===============================
// Elements
// ===============================

const chatBox =
document.getElementById("chatBox");

const userInput =
document.getElementById("userInput");

const settingsPanel =
document.getElementById("settingsPanel");

// ===============================
// Save Local Chat
// ===============================

function saveLocalChat(){

localStorage.setItem(
"chatHistory",
chatBox.innerHTML
);

}

// ===============================
// Load Local Chat
// ===============================

function loadLocalChat(){

let data =
localStorage.getItem("chatHistory");

if(data){

chatBox.innerHTML=data;

}

}

// ===============================
// Theme
// ===============================

function loadTheme(){

let theme=
localStorage.getItem("theme");

if(theme==="dark"){

document.body.classList.add("dark-mode");

}

}

// ===============================
// Page Load
// ===============================

window.onload=function(){

loadLocalChat();

loadTheme();

chatBox.scrollTop=
chatBox.scrollHeight;

};

// ===============================
// SEND MESSAGE
// ===============================

async function sendMessage(){

let message=userInput.value.trim();

if(message==="") return;

// User Message

chatBox.innerHTML+=`

<div class="message user-wrapper">

<div class="user-message">

${message}

<div class="time">

${new Date().toLocaleTimeString([],{
hour:"2-digit",
minute:"2-digit"
})}

</div>

</div>

</div>

`;

saveLocalChat();

chatBox.scrollTop=chatBox.scrollHeight;

userInput.value="";

// Typing Animation

chatBox.innerHTML+=`

<div class="message" id="typingBox">

<div class="avatar">🤖</div>

<div class="typing">

<span></span>

<span></span>

<span></span>

</div>

</div>

`;

chatBox.scrollTop=chatBox.scrollHeight;

let aiReply="";

try{

const response=await fetch(SERVER_URL+"/chat",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({

message:message

})

});

const data=await response.json();

aiReply=data.reply;

}
catch(error){

aiReply="❌ Server se connect nahi ho pa raha.";

}

// Remove Typing

document.getElementById("typingBox")?.remove();

// AI Message

chatBox.innerHTML+=`

<div class="message">

<div class="avatar">

🤖

</div>

<div class="ai-message">

${aiReply}

<div class="time">

${new Date().toLocaleTimeString([],{
hour:"2-digit",
minute:"2-digit"
})}

</div>

</div>

</div>

`;

saveLocalChat();

chatBox.scrollTop=chatBox.scrollHeight;

}

// ===============================
// FIRESTORE SAVE
// ===============================

async function saveMessage(sender, message){

try{

await addDoc(

collection(db,"chats"),

{

uid:auth.currentUser.uid,

sender:sender,

message:message,

time:serverTimestamp()

}

);

}
catch(error){

console.log("Firestore Error:",error);

}

}

// ===============================
// FIRESTORE LOAD
// ===============================

async function loadFirestoreChats(){

try{

const q=query(

collection(db,"chats"),

where("uid","==",auth.currentUser.uid),

orderBy("time","asc")

);

const snapshot=await getDocs(q);

chatBox.innerHTML="";

snapshot.forEach((doc)=>{

const chat=doc.data();

if(chat.sender==="user"){

chatBox.innerHTML+=`

<div class="message user-wrapper">

<div class="user-message">

${chat.message}

</div>

</div>

`;

}else{

chatBox.innerHTML+=`

<div class="message">

<div class="avatar">🤖</div>

<div class="ai-message">

${chat.message}

</div>

</div>

`;

}

});

chatBox.scrollTop=chatBox.scrollHeight;

}
catch(error){

console.log(error);

}

}

// ===============================
// VOICE INPUT (PART 4)
// ===============================

let recognition;

if ("webkitSpeechRecognition" in window) {

    recognition = new webkitSpeechRecognition();

    recognition.continuous = false;

    recognition.interimResults = false;

    recognition.lang = "hi-IN";

} else {

    alert("Voice Recognition is not supported in this browser.");

}

// ===============================
// START VOICE
// ===============================

window.startVoice = function () {

    if (!recognition) return;

    recognition.start();

};

// ===============================
// VOICE RESULT
// ===============================

recognition.onresult = function (event) {

    const voiceText = event.results[0][0].transcript;

    userInput.value = voiceText;

    sendMessage();

};

// ===============================
// VOICE ERROR
// ===============================

recognition.onerror = function (event) {

    console.log("Voice Error:", event.error);

};

// ===============================
// VOICE END
// ===============================

recognition.onend = function () {

    console.log("Voice Recognition Stopped");

};

// ===============================
// SETTINGS PANEL
// ===============================

function openSettings(){

    settingsPanel.style.display = "block";

}

function closeSettings(){

    settingsPanel.style.display = "none";

}

// ===============================
// DARK MODE
// ===============================

function toggleDarkMode(){

    document.body.classList.toggle("dark-mode");

    if(document.body.classList.contains("dark-mode")){

        localStorage.setItem("theme","dark");

    }else{

        localStorage.setItem("theme","light");

    }

}

// ===============================
// CLICK OUTSIDE TO CLOSE SETTINGS
// ===============================

window.addEventListener("click",function(e){

    if(
        settingsPanel.style.display==="block" &&
        !settingsPanel.contains(e.target) &&
        !e.target.classList.contains("header-btn")
    ){

        closeSettings();

    }

});

// ===============================
// PART 6
// NEW CHAT + CLEAR CHAT
// ===============================

// New Chat

function newChat(){

    if(confirm("Nayi Chat shuru karni hai?")){

        chatBox.innerHTML=`

        <div class="message">

            <div class="avatar">🤖</div>

            <div class="ai-message">

                Hello 👋<br>

                Main <b>NeuroChat AI</b> hoon.

                Main aapki madad ke liye hamesha ready hoon.

                <div class="time">

                    Just Now

                </div>

            </div>

        </div>

        `;

        localStorage.removeItem("chatHistory");

    }

}

// ===============================
// CLEAR CHAT
// ===============================

function clearChat(){

    if(confirm("Kya aap puri chat delete karna chahte hain?")){

        chatBox.innerHTML="";

        localStorage.removeItem("chatHistory");

    }

}

// ===============================
// LOAD CHAT
// ===============================

function loadChat(){

    let chat=

    localStorage.getItem("chatHistory");

    if(chat){

        chatBox.innerHTML=chat;

    }

}

// ===============================
// PAGE LOAD
// ===============================

window.addEventListener("load",()=>{

    loadChat();

});

// ===============================
// EXPORT
// ===============================

window.newChat=newChat;

window.clearChat=clearChat;

// ===============================
// PART 7
// LOGOUT + ENTER KEY + AUTO SCROLL
// ===============================

// Logout

async function logout(){

    try{

        await signOut(auth);

        alert("Logout Successful");

        window.location.href="login.html";

    }
    catch(error){

        alert("Logout Failed : " + error.message);

    }

}

// ===============================
// ENTER KEY
// ===============================

userInput.addEventListener("keypress",function(e){

    if(e.key==="Enter"){

        e.preventDefault();

        sendMessage();

    }

});

// ===============================
// AUTO SCROLL
// ===============================

function scrollBottom(){

    setTimeout(()=>{

        chatBox.scrollTop=chatBox.scrollHeight;

    },100);

}

// ===============================
// AUTO SCROLL ON LOAD
// ===============================

window.addEventListener("load",()=>{

    scrollBottom();

});

// ===============================
// SAVE CHAT
// ===============================

function saveChat(){

    localStorage.setItem(

        "chatHistory",

        chatBox.innerHTML

    );

}

// ===============================
// EXPORT
// ===============================

window.logout=logout;

window.sendMessage=sendMessage;

window.startVoice=startVoice;

// ===============================
// PART 8 (FINAL)
// FINAL FUNCTIONS
// ===============================

// Window Export

window.sendMessage = sendMessage;
window.startVoice = startVoice;
window.newChat = newChat;
window.clearChat = clearChat;
window.openSettings = openSettings;
window.closeSettings = closeSettings;
window.toggleDarkMode = toggleDarkMode;
window.logout = logout;

// Welcome

console.log("✅ NeuroChat V2 Loaded");

// Auto Focus

window.addEventListener("load",()=>{

    if(userInput){

        userInput.focus();

    }

});

// Prevent Empty Space

chatBox.addEventListener("DOMNodeInserted",()=>{

    chatBox.scrollTop=chatBox.scrollHeight;

});

