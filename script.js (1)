import { auth, db } from "./firebase.js";

import {
  collection,
  addDoc,
  serverTimestamp
} from "https://www.gstatic.com/firebasejs/12.0.0/firebase-firestore.js";

import { signOut } from "https://www.gstatic.com/firebasejs/12.0.0/firebase-auth.js";

const SERVER_URL = "https://my-ai-app-5.onrender.com";

// Save Chat
function saveChat() {
    let chatBox = document.getElementById("chatBox");
    localStorage.setItem("chatHistory", chatBox.innerHTML);
}

// Send Message
async function sendMessage() {

    let input = document.getElementById("userInput");
    let chatBox = document.getElementById("chatBox");

    let message = input.value.trim();

    if (message === "") {
        alert("Pehle kuch likhiye!");
        return;
    }

    let time = new Date().toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit"
    });

    // User Message
    chatBox.innerHTML += `
    <div class="message">
        <div class="avatar">👤</div>
        <div class="user-message">
            ${message}
            <div class="time">${time}</div>
        </div>
    </div>`;

    input.value = "";
    chatBox.scrollTop = chatBox.scrollHeight;
    saveChat();
try {
    await addDoc(collection(db, "chats"), {
        uid: auth.currentUser.uid,
        sender: "user",
        message: message,
        time: serverTimestamp()
    });
} catch (error) {
    console.log("Firestore Error:", error);
}

    // Typing
    chatBox.innerHTML += `
    <div id="typing" class="message">
        <div class="avatar">🤖</div>
        <div class="ai-message">Typing...</div>
    </div>`;

    chatBox.scrollTop = chatBox.scrollHeight;

    setTimeout(async function () {

        let typing = document.getElementById("typing");
        if (typing) typing.remove();

        let aiReply = "";

        try {

            const response = await fetch(`${SERVER_URL}/chat`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    message: message
                })
            });

            const data = await response.json();

            aiReply = data.reply;

try {
    await addDoc(collection(db, "chats"), {
        uid: auth.currentUser.uid,
        sender: "ai",
        message: aiReply,
        time: serverTimestamp()
    });
} catch (error) {
    console.log("Firestore AI Save Error:", error);
}

speak(aiReply);

      } catch (error) {

            aiReply = "❌ Server se connect nahi ho pa raha.";

        }

        chatBox.innerHTML += `
        <div class="message">
            <div class="avatar">🤖</div>
            <div class="ai-message">
                ${aiReply}
                <div class="time">${time}</div>
            </div>
        </div>`;

        chatBox.scrollTop = chatBox.scrollHeight;
        saveChat();

    }, 1000);

}

// Enter Key
document.getElementById("userInput").addEventListener("keypress", function(e){
    if(e.key === "Enter"){
        sendMessage();
    }
});

// Clear Chat
function clearChat(){

    if(confirm("Kya aap sari chat delete karna chahte hain?")){

        document.getElementById("chatBox").innerHTML = "";

        localStorage.removeItem("chatHistory");

    }

}

// Dark Mode
function toggleDarkMode(){

    document.body.classList.toggle("dark-mode");

    if(document.body.classList.contains("dark-mode")){
        localStorage.setItem("theme","dark");
    }else{
        localStorage.setItem("theme","light");
    }

}

// Load Data
window.onload = function(){

    let chat = localStorage.getItem("chatHistory");

    if(chat){
        document.getElementById("chatBox").innerHTML = chat;
    }

    let theme = localStorage.getItem("theme");

    if(theme === "dark"){
        document.body.classList.add("dark-mode");
    }

}

// Settings
function openSettings(){
    document.getElementById("settingsPanel").style.display = "block";
}

function closeSettings(){
    document.getElementById("settingsPanel").style.display = "none";
}

// Voice Input
function startVoice(){

    let SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    if(!SpeechRecognition){
        alert("Voice recognition is not supported in this browser.");
        return;
    }

    let recognition = new SpeechRecognition();

    recognition.lang = "en-IN";
    recognition.start();

    recognition.onresult = function(event){

        let text = event.results[0][0].transcript;

        document.getElementById("userInput").value = text;

        sendMessage();
    };

    recognition.onerror = function(){
        alert("Voice input error ho gaya!");
    };

}

// Logout
async function logout() {

    try {

        await signOut(auth);

        alert("Logout Successful");

        window.location.href = "login.html";

    } catch (error) {

        alert("Logout Failed: " + error.message);

    }

}

// AI Voice
function speak(text) {

    let speech = new SpeechSynthesisUtterance(text);

    speech.lang = "hi-IN";
    speech.rate = 1;
    speech.pitch = 1;
    speech.volume = 1;

    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(speech);
}

// HTML buttons ko module functions se connect karo
window.sendMessage = sendMessage;
window.clearChat = clearChat;
window.toggleDarkMode = toggleDarkMode;
window.openSettings = openSettings;
window.closeSettings = closeSettings;
window.startVoice = startVoice;
window.logout = logout;
window.speak = speak;
